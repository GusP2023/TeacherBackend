# ========================================
# ENTORNO
# ========================================
ENVIRONMENT=development
DEBUG=true

# ========================================
# BASE DE DATOS
# ========================================
# Formato: postgresql+asyncpg://usuario:contrasena@host:puerto/nombre_base_datos
# Para usar async con SQLAlchemy, DEBE tener el prefijo postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:4715@localhost:5432/music_school
# Render cloud (no funciona actualmente):
#DATABASE_URL=postgresql+asyncpg://music_teacher_cy8v_user:E4Bja7eCiw8Pb6EcLnWHYfM5i9AblzWp@dpg-d3u139n5r7bs73f6b7jg-a.oregon-postgres.render.com/music_teacher_cy8v

# ========================================
# SEGURIDAD
# ========================================
# IMPORTANTE: Cambia este SECRET_KEY en produccion
# Puedes generar uno con: openssl rand -hex 32
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=3000

# ========================================
# API
# ========================================
API_V1_PREFIX=/api/v1
PROJECT_NAME=ProfesorSYS

# ========================================
# CORS (Frontend URLs permitidas)
# ========================================
# Agrega las URLs de tu frontend separadas por comas
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://192.168.0.3:8081,http://192.168.0.3,http://192.168.0.X:5173,capacitor://localhost,ionic://localhost

# ========================================
# TARIFAS POR DEFECTO
# ========================================
DEFAULT_TARIFF_INDIVIDUAL=50.00
DEFAULT_TARIFF_GROUP=35.00
DEFAULT_CLASS_DURATION=45
